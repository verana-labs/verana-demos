# =============================================================================
# Verifier Chatbot VS — Configuration
# =============================================================================
#
# This file is read by the setup scripts and GHA workflow.
# It contains all configuration needed for the Verifier Chatbot child service.
#
# For local testing:
#   source verifier-chatbot-vs/config.env
#   ./verifier-chatbot-vs/scripts/setup.sh
#
# =============================================================================

# ---------------------------------------------------------------------------
# Network (derived from branch name in GHA; set manually for local usage)
# ---------------------------------------------------------------------------
# NETWORK="testnet"

# ---------------------------------------------------------------------------
# Veranad CLI account name
# ---------------------------------------------------------------------------
USER_ACC="org-vs-admin"

# ---------------------------------------------------------------------------
# Organization VS — parent service
# The DID of organization-vs is needed to discover the credential definition.
# Set to the public URL of the organization-vs agent (K8s or local).
# The admin API is used to request Service credentials.
# ---------------------------------------------------------------------------
ORG_VS_PUBLIC_URL="${ORG_VS_PUBLIC_URL:-}"
ORG_VS_ADMIN_URL="${ORG_VS_ADMIN_URL:-http://localhost:3000}"

# ---------------------------------------------------------------------------
# VS Agent image and ports (local development)
# Use different ports than other services to avoid collision.
# ---------------------------------------------------------------------------
VS_AGENT_IMAGE="${VS_AGENT_IMAGE:-veranalabs/vs-agent:latest}"
VS_AGENT_CONTAINER_NAME="verifier-chatbot-vs"
VS_AGENT_ADMIN_PORT="3006"
VS_AGENT_PUBLIC_PORT="3007"

# ---------------------------------------------------------------------------
# Service details
# These appear in the Service credential issued by organization-vs.
# ---------------------------------------------------------------------------
SERVICE_NAME="Example Verifier Chatbot"
SERVICE_TYPE="VerifierService"
SERVICE_DESCRIPTION="Chatbot credential verifier for the Verana demo ecosystem"
SERVICE_LOGO_URL="https://verana.io/logo.svg"
SERVICE_MIN_AGE="0"
SERVICE_TERMS="https://verana-labs.github.io/governance-docs/EGF/example.pdf"
SERVICE_PRIVACY="https://verana-labs.github.io/governance-docs/EGF/example.pdf"

# ---------------------------------------------------------------------------
# Issuer VS — the issuer whose credential definition this verifier targets
# Set to the public URL of the issuer-chatbot-vs agent (K8s or local).
# ---------------------------------------------------------------------------
ISSUER_VS_PUBLIC_URL="${ISSUER_VS_PUBLIC_URL:-http://localhost:3003}"

# ---------------------------------------------------------------------------
# Chatbot configuration
# ---------------------------------------------------------------------------
CHATBOT_PORT="4002"

# Session persistence
# Local: SQLite file path
# K8s:   PostgreSQL connection string (e.g., postgresql://user:pass@host:5432/db)
DATABASE_URL="sqlite:./data/sessions.db"

# Logging level (debug, info, warn, error)
LOG_LEVEL="info"
