# =============================================================================
# Organization VS — Configuration
# =============================================================================
#
# This file is read by the setup scripts and GHA workflow.
# It contains all configuration needed for the Organization VS service.
#
# For local testing:
#   source organization-vs/config.env
#   ./organization-vs/scripts/setup.sh
#
# =============================================================================

# ---------------------------------------------------------------------------
# Network (derived from branch name in GHA; set manually for local usage)
# ---------------------------------------------------------------------------
# NETWORK="testnet"

# ---------------------------------------------------------------------------
# Veranad CLI account name
# ---------------------------------------------------------------------------
USER_ACC="org-vs-admin"

# ---------------------------------------------------------------------------
# VS Agent image and ports (local development)
# ---------------------------------------------------------------------------
VS_AGENT_IMAGE="${VS_AGENT_IMAGE:-veranalabs/vs-agent:latest}"
VS_AGENT_CONTAINER_NAME="organization-vs"
VS_AGENT_ADMIN_PORT="3000"
VS_AGENT_PUBLIC_PORT="3001"

# ---------------------------------------------------------------------------
# Expose admin API publicly (K8s only)
# When "true", the workflow deploys a standalone ingress at
# admin.organization-vs.<VS_NAME>.demos.<NETWORK>.testnet.verana.network
# exposing only the W3C issuance endpoint (/v1/vt/issue-credential) and
# Swagger UI (/api). The full admin API is NOT exposed.
# ---------------------------------------------------------------------------
EXPOSE_ADMIN_API="true"

# ---------------------------------------------------------------------------
# Organization details
# These appear in the Organization credential issued by the ECS TR.
# ---------------------------------------------------------------------------
ORG_NAME="Verana Example Organization"
ORG_COUNTRY="CH"
ORG_LOGO_URL="https://verana.io/logo.svg"
ORG_REGISTRY_ID="CH-CHE-123.456.789"
ORG_ADDRESS="Bahnhofstrasse 42, 8001 Zurich, Switzerland"

# ---------------------------------------------------------------------------
# Service details
# These appear in the Service credential self-issued by the VS Agent.
# ---------------------------------------------------------------------------
SERVICE_NAME="Example Organization Service"
SERVICE_TYPE="IssuerService"
SERVICE_DESCRIPTION="Organization service for the Verana demo ecosystem"
SERVICE_LOGO_URL="https://verana.io/logo.svg"
SERVICE_MIN_AGE="0"
SERVICE_TERMS="https://verana-labs.github.io/governance-docs/EGF/example.pdf"
SERVICE_PRIVACY="https://verana-labs.github.io/governance-docs/EGF/example.pdf"

# ---------------------------------------------------------------------------
# Trust Registry configuration
# ---------------------------------------------------------------------------

# Custom schema — read from schema.json by default.
# Override with a URL if you want to use a remote schema.
# CUSTOM_SCHEMA_URL="https://verana-labs.github.io/verifiable-trust-spec/schemas/v4/example.json"

# Base ID for the VTJSC (used in DID Document service entries)
CUSTOM_SCHEMA_BASE_ID="example"

# Ecosystem Governance Framework document
# Digest is auto-calculated at runtime if left empty.
EGF_DOC_URL="https://verana-labs.github.io/governance-docs/EGF/example.pdf"
# EGF_DOC_DIGEST=""

# Trust Registry URL (defaults to the public ingress URL from deployment.yaml)
# TR_REGISTRY_URL="https://my-service.example.com"

# ---------------------------------------------------------------------------
# AnonCreds (optional — set to true to enable dual W3C + AnonCreds issuance)
# ---------------------------------------------------------------------------
ENABLE_ANONCREDS="true"
ANONCREDS_NAME="example"
ANONCREDS_VERSION="1.0"
ANONCREDS_SUPPORT_REVOCATION="false"
