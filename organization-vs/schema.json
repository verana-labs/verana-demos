{
  "$id": "https://verana-labs.github.io/verifiable-trust-spec/schemas/v4/example.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Student Credential",
  "description": "A Student Credential Schema for UCD.",
  "type": "object",
  "properties": {
    "credentialSubject": {
      "type": "object",
      "properties": {
        "firstName": {
          "type": "string",
          "description": "First Name"
        },
        "lastName": {
          "type": "string",
          "description": "Last Name"
        },
        "dateOfBirth": {
          "type": "string",
          "description": "Date of Birth"
        },
        "studentNumber": {
          "type": "string",
          "description": "The student number"
        },
        "emailAddress": {
          "type": "string",
          "description": "The student's email address"
        },
        "programme": {
          "type": "string",
          "description": "The student's degree programme"
        }
      },
      "required": [
        "firstName",
        "lastName",
        "dateOfBirth",
        "studentNumber",
        "emailAddress",
        "programme"
      ]
    }
  }
}
